{
  "name": "treescope",
  "displayName": "TreeScope",
  "description": "Generate clean file tree structure for your project instantly",
  "icon": "public/icon.png",
  "version": "0.0.3",
  "publisher": "owsam22",
  "license": "MIT",

  "engines": {
    "vscode": "^1.85.0"
  },

  "categories": ["Other"],

  "main": "./out/extension.js",
  
  "activationEvents": ["*"],

  "repository": {
    "type": "git",
    "url": "https://github.com/owsam22/treescope-vscode-extention"
  },

  "contributes": {
    "commands": [
      {
        "command": "treescope.generateFromFolder",
        "title": "TreeScope: Generate File Tree (Selected Folder)"
      },
      {
        "command": "treescope.generateFromWorkspace",
        "title": "TreeScope: Generate File Tree (Workspace Root)"
      }
    ],

    "menus": {
      "explorer/context": [
        {
          "command": "treescope.generateFromFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}